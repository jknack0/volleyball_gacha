# LF everywhere (tooling-pipeline §3)
* text=auto eol=lf

# Unity YAML stays plain-text git — the review surface
*.unity text
*.prefab text
*.asset text
*.meta text
*.asmdef text
*.json text

# Binaries via LFS
*.png filter=lfs diff=lfs merge=lfs -text
